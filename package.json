{
  "name": "job-portal",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "dotenv": "^17.4.2",
      "zod": "^4.4.3",
      "@types/bun": "^1.3.14",
      "better-auth": "^1.6.11",
      "stripe": "^22.1.1",
      "react": "^19.2.6",
      "@types/react": "^19.2.15",
      "jest": "^30.4.2",
      "@types/jest": "^30.0.0",
      "ts-jest": "^29.4.11",
      "@jest/globals": "^30.4.1",
      "jest-environment-jsdom": "^30.4.1"
    }
